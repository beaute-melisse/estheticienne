        linear-gradient(135deg, rgba(244,231,215,1), rgba(234,215,192,1));
    }
    .banner::after{
      content:"";
      position:absolute; inset:0;
      background: linear-gradient(90deg, rgba(255,255,255,.18), rgba(255,255,255,.08) 55%, rgba(255,255,255,0));
      pointer-events:none;
    }
    .banner-inner{
      position:relative;
      padding: 38px 34px;
      display:flex;
      flex-direction:column;
      gap: 10px;
    }
    .headline{
      font-family:"Playfair Display", serif;
      font-weight:800;
      font-size: clamp(30px, 3.2vw, 44px);
      line-height: 1.1;
      margin:0;
      letter-spacing:.2px;
    }
    .lead{
      margin:0;
      font-size: 16px;
      color: rgba(63,46,31,.86);
      max-width: 72ch;
    }
    .pill{
      display:flex; gap:10px; flex-wrap:wrap;
      margin-top: 6px;
    }
    .tag{
      display:inline-flex; align-items:center; gap:10px;
      padding:10px 12px;
      border-radius:999px;
      background: rgba(255,255,255,.35);
      border:1px solid var(--stroke);
      box-shadow: 0 10px 22px rgba(63,46,31,.08);
      font-weight:700;
      color: rgba(63,46,31,.92);
    }
    .dot{
      width:9px; height:9px; border-radius:999px;
      background: var(--accent);
      box-shadow: 0 0 0 4px rgba(48,87,24,.12);
    }

    .legal{
      margin-top: 22px;
      display:grid;
      gap: 14px;
    }
    .panel{
      border-radius: var(--radius2);
      border:1px solid var(--stroke);
      background: rgba(255,255,255,.35);
      box-shadow: 0 12px 28px rgba(63,46,31,.08);
      padding: 18px;
    }
    .panel h2{
      margin: 0 0 10px;
      font-family:"Playfair Display", serif;
      font-size: 22px;
      letter-spacing:.2px;
    }
    .panel p{ margin: 0; color: rgba(63,46,31,.84); }
    .panel p + p{ margin-top: 10px; }

    .kv{
      margin-top: 10px;
      display:grid;
      gap: 10px;
    }
    .row{
      display:grid;
      grid-template-columns: 180px 1fr;
      gap: 12px;
      padding: 12px 12px;
      border-radius: 16px;
      border:1px solid rgba(63,46,31,.14);
      background: rgba(255,255,255,.25);
    }
    .k{
      font-weight: 900;
      color: rgba(63,46,31,.86);
    }
    .v{
      color: rgba(63,46,31,.84);
      word-break: break-word;
    }
    .subnote{
