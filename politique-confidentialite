      --text: #3f2e1f;
      --accent: #305718;
      --btn: #7fa77a;
      --btn-dark: #43290c;
      --btn-text: #ffffff;
      --bg: #f4e7d7;
      --bg2: #ead7c0;
      --card: rgba(255,255,255,.55);
      --stroke: rgba(63,46,31,.18);
      --shadow: 0 14px 35px rgba(63,46,31,.15);
      --radius: 18px;
      --radius2: 26px;
      --max: 1120px;
    }

    *{ box-sizing:border-box; }
    html{ scroll-behavior:smooth; }
    body{
      margin:0;
      color:var(--text);
      background:
        radial-gradient(1200px 600px at 10% -10%, rgba(127,167,122,.20), transparent 60%),
        radial-gradient(900px 500px at 110% 10%, rgba(48,87,24,.14), transparent 55%),
        linear-gradient(180deg, var(--bg), var(--bg2));
      font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      line-height:1.55;
    }

    a{ color:inherit; text-decoration:none; }
    img{ max-width:100%; display:block; }
    .container{ width:min(var(--max), calc(100% - 48px)); margin-inline:auto; }

    /* =========================
       HEADER — LOGO À GAUCHE XXL
       ========================= */
    header{
      position:sticky;
      top:0;
      z-index:50;
      backdrop-filter: blur(10px);
      background: rgba(244,231,215,.85);
      border-bottom:1px solid var(--stroke);
    }

    .nav{
      display:flex;
      align-items:center;
      justify-content:space-between;
      padding: 14px 0;
      gap: 18px;
    }

    .brand{
      display:flex;
      align-items:center;
      gap:12px;
    }
    .brand img{
      height: 200px;
      width:auto;
      filter: drop-shadow(0 14px 26px rgba(63,46,31,.25));
    }

    .nav-right{
      display:flex;
      align-items:center;
      gap: 18px;
    }

    .navlinks{
      display:flex;
      align-items:center;
      gap: 18px;
    }

    .navlinks a{
      position:relative;
      font-weight:800;
      padding:10px 6px;
      opacity:.95;
    }

    .navlinks a::after{
      content:"";
      position:absolute;
      left:6px; right:6px; bottom:6px;
      height:2px;
      background: linear-gradient(90deg, transparent, var(--accent), transparent);
      transform: scaleX(0);
      transition: transform .2s ease;
    }
    .navlinks a:hover::after{ transform: scaleX(1); }

    .btn{
      display:inline-flex;
      align-items:center;
      gap:10px;
      padding:12px 18px;
      border-radius:999px;
      background: linear-gradient(180deg, var(--btn), #6f9f6a);
      color:#fff;
      font-weight:900;
      border:1px solid rgba(255,255,255,.25);
      box-shadow: 0 14px 30px rgba(67,41,12,.22);
      transition: transform .15s ease, box-shadow .15s ease;
      white-space:nowrap;
    }
    .btn:hover{
      transform: translateY(-2px);
      box-shadow: 0 18px 38px rgba(67,41,12,.28);
    }
    .wa-dot{
      width:10px;
      height:10px;
      border-radius:50%;
      background:#fff;
    }

    .burger{
      display:none;
      width:44px;
      height:44px;
      border-radius:12px;
      border:1px solid var(--stroke);
      background: rgba(255,255,255,.35);
      align-items:center;
      justify-content:center;
      cursor:pointer;
    }
    .burger span{
      width:18px;
      height:2px;
      background: var(--text);
      position:relative;
    }
    .burger span::before,
    .burger span::after{
      content:"";
      position:absolute;
      left:0;
      width:18px;
      height:2px;
      background: var(--text);
    }
    .burger span::before{ top:-6px; }
    .burger span::after{ top:6px; }

    .mobile-panel{
      display:none;
      padding: 10px 0 18px;
    }
    header[data-open="true"] .mobile-panel{
      display:block;
    }
    .mobile-panel .navlinks{
      flex-direction:column;
      align-items:flex-start;
      gap:10px;
    }

    @media (max-width: 900px){
      .nav > .nav-right > nav.navlinks{ display:none; }
      .burger{ display:flex; }
      header[data-open="true"] .mobile-panel{ display:block; }
      .mobile-panel nav.navlinks{ display:flex; }
      .brand img{ height: 96px; }
    }

    @media (max-width: 860px){
      .nav{
        flex-direction: column;
        align-items: stretch;
        gap: 12px;
      }
      .brand{ justify-content: center; }
      .brand img{ height: 120px; }
      .nav-right{
        width:100%;
        display:flex;
        justify-content: space-between;
        align-items:center;
      }
      .nav > .nav-right > nav.navlinks{ display:none; }
      .burger{ display:flex; }
      header[data-open="true"] .mobile-panel{ display:block; }
      .mobile-panel nav.navlinks{ display:flex; flex-direction:column; align-items:flex-start; gap:10px; }
