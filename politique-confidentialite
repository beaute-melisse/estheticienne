    /* =========================
       PAGE — MENTIONS LÉGALES
       ========================= */
    main{ padding: 34px 0 84px; }
    .page-hero{
      padding: 34px 0 18px;
    }

    .banner{
      position:relative;
      border-radius: 32px;
      overflow:hidden;
      border:1px solid rgba(255,255,255,.45);
      box-shadow: var(--shadow);
      background:
        radial-gradient(900px 520px at 18% 18%, rgba(127,167,122,.28), transparent 62%),
